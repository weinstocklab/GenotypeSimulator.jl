# ╔═╡ a6f44ef0-59d3-4b77-8589-823cbf503490
function sim(rho = 1e-8)
	params = PopulationParams(
	    20_000,     # Effective population size (human)
	    1.25e-8,    # Human mutation rate per bp per generation
		rho,       # Human recombination rate per bp per generation
	    10_000,  # 0.1Mb sequence length
	    200        # Large sample size (100 individuals)
	)
	neutral_genotypes, neutral_positions = simulate_with_recombination_adaptive(params)
	neutral_diploid = haplotypes_to_diploid(neutral_genotypes)
	eigvals(cor(neutral_diploid))
end

# ╔═╡ 3daa8ca1-f560-4641-acdc-c1a18803f928
function all_sims()
	n_sims = 3
	ρ_range = [1.25e-8, 3e-8, 5e-8]
	ρ_vec = ones(n_sims * length(ρ_range))
	variances = ones(n_sims * length(ρ_range))
	
	@inbounds for i in 1:n_sims
		for j in 1:length(ρ_range)
			evals = sim(ρ_range[j])
			GC.gc()
			variances[j + length(ρ_range) * (i - 1)] = var(abs.(evals))
			ρ_vec[j + length(ρ_range) * (i - 1)] = ρ_range[j]
			println("Done with $i, $(ρ_range[j])")
		end
	end

	return variances, ρ_vec
end

# ╔═╡ cb03dc06-4f3f-4a8c-a8db-9b67040e7433
@time res = all_sims()

